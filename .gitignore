# Python
__pycache__/
**/__pycache__/
*.py[cod]
*.so
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
**/.venv/
venv/
**/venv/

# Ignore real environment files
.env
**/.env

# Ignore all env variants except the example template
.env.*
**/.env.*

# Keep example files
!.env.example
!**/.env.example

